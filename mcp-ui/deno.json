{
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler"
  },
  "imports": {
    "@modelcontextprotocol/ext-apps": "npm:@modelcontextprotocol/ext-apps@^1.3.1",
    "@modelcontextprotocol/sdk/types.js": "npm:@modelcontextprotocol/sdk@^1.27.1/types.js",
    "typescript": "npm:typescript@^5.9.3",
    "vite": "npm:vite@^6.3.5",
    "vite-plugin-singlefile": "npm:vite-plugin-singlefile@^2.3.0"
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "install-deps": "deno install --allow-scripts=npm:esbuild --frozen",
    "build": "deno run -A npm:vite build"
  }
}
